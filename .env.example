# Supabase Configuration (Required for Next.js client & server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (used for email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only variables (for scripts)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Root admin credentials (for create-root-admin script)
ROOT_ADMIN_EMAIL=admin@example.com
ROOT_ADMIN_PASSWORD=your_secure_password

# Production
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
